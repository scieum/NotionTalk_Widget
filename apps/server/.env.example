# Notion 내부 통합 토큰 (https://www.notion.so/my-integrations 에서 발급)
# 기록 DB 페이지에서 ⋯ → 연결 → 이 통합을 공유해야 읽기/쓰기가 됩니다.
NOTION_TOKEN=

# 기본 뽀모도로 기록 DB ID (선택 — 위젯 설정에서 DB ID를 비우면 이 값 사용)
# DB 링크 https://notion.so/xxxx?v=... 에서 xxxx 부분(32자리)
NOTION_POMODORO_DB=

# 서버 포트 (기본 8787)
PORT=8787

# SQLite 데이터 경로 (기본 ./data)
DATA_DIR=./data
